# ============================================
# MediExpress Backend Environment Variables
# ============================================

# MongoDB Connection (REQUIRED)
# Get from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# JWT Secret (REQUIRED)
# Generate a strong random string for production
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

# Cloudinary Configuration (REQUIRED for image/video uploads)
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Gmail SMTP Configuration (REQUIRED for OTP emails)
# Get App Password from: https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password

# Firebase Admin SDK (OPTIONAL - for push notifications)
# Get from: https://console.firebase.google.com/project/settings/serviceaccounts/adminsdk
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Application Configuration
NODE_ENV=production
PORT=3000

# ============================================
# IMPORTANT NOTES:
# ============================================
# 1. Copy this file to .env.local for local development
# 2. Set these same variables in Vercel Dashboard for production
# 3. Never commit .env.local to git
# 4. Firebase variables are optional - app works without push notifications
# 5. All other variables are REQUIRED for the app to function properly
